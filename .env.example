# ── LLM Provider (Groq — Llama 3) ─────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=                          # get a free key at console.groq.com

# ── LangSmith (optional — enable for tracing & evaluation) ────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=                     # get at smith.langchain.com
LANGCHAIN_PROJECT=credit-risk-agent-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── RBAC user directory (optional — leave blank for demo/dev mode) ─────────────
# JSON object: {"username":{"password":"secret","role":"underwriter"}}
# Roles: viewer | underwriter | auditor | admin
# APP_RBAC_USERS={"alice":{"password":"pass1","role":"underwriter"},"bob":{"password":"pass2","role":"admin"}}
