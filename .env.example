OPENAI_API_KEY=your-openai-api-key-here
# LLM: openai | gemini | groq | llama3 | ollama  (llama3 = Groq-hosted Llama 3)
LLM_PROVIDER=openai

# Gemini (LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your-google-ai-api-key-here
# GEMINI_MODEL=gemini-2.0-flash

# Groq — Llama 3 (LLM_PROVIDER=groq or llama3)
GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=llama-3.3-70b-versatile

# Ollama — local Llama (LLM_PROVIDER=ollama, run: ollama pull llama3)
# OLLAMA_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=credit-risk-agent-system
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Optional: RBAC for Streamlit UI (`streamlit run ui/app.py`). JSON object: username -> {password, role}.
# Roles: viewer | underwriter | auditor | admin. If unset, the UI runs in demo mode (pick a role without a password).
# APP_RBAC_USERS={"demo_uw":{"password":"changeme","role":"underwriter"},"demo_auditor":{"password":"changeme","role":"auditor"}}
